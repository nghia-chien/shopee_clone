    "@types/multer": "^2.0.0",
    "@types/node": "^24.9.2",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prisma": "6.19.0",
    "ts-node": "^10.9.2",
